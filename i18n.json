{
  "$schema": "https://lingo.dev/schema/i18n.json",
  "version": "1.10",
  "locale": {
    "source": "en",
    "targets": ["de", "es", "fr"]
  },
  "buckets": {
    "xcode-xcstrings": {
      "include": [
        "AtlasMe/Localizable.xcstrings",
        "AtlasSharedKit/Localizable.xcstrings",
        "StatisticsWidgets/Localizable.xcstrings"
      ]
    }
  },
  "provider": {
    "id": "openrouter",
    "model": "openai/gpt-oss-120b",
    "prompt": "Translate {source} to {target}"
  }
}
